{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "make check-agent-memory >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "make agents-db AGENTS_ARGS='validate' >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/debrief_nudge.sh || true"
          },
          {
            "type": "command",
            "command": "scripts/kg/auto_refresh.sh || true",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
