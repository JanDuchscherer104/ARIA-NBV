flowchart TB
  %% Global pooling + voxel FiLM (compact)

  Field["$$\\begin{array}{c}\\textbf{Scene field}\\\\\\mathbf{F}\\end{array}$$"]
  PoseEnc["$$\\begin{array}{c}\\textbf{Pose embedding}\\\\\\mathbf{e}_{\\mathrm{pose}}\\end{array}$$"]
  Cam["$$\\begin{array}{c}\\textbf{Candidate cameras}\\\\C_q\\end{array}$$"]

  GlobalPool["$$\\begin{array}{c}\\textbf{PoseConditionedGlobalPool}\\\\(7.3K\\ \\text{params})\\\\\\mathbf{g}=\\texttt{PoseConditionedGlobalPool}(\\mathbf{F},\\mathbf{e}_{\\mathrm{pose}})\\end{array}$$"]

  GlobalPoolOps["$$\\begin{array}{c}\\textbf{Internal ops}\\\\\\texttt{nn.Linear}\\rightarrow\\texttt{nn.MultiheadAttention}\\\\\\rightarrow\\texttt{nn.Sequential}\\rightarrow\\texttt{nn.LayerNorm}\\end{array}$$"]

  VoxPool["$$\\begin{array}{c}\\textbf{Voxel pooling}\\\\\\mathbf{p}=\\texttt{nn.AdaptiveAvgPool3d}(\\mathbf{F})\\end{array}$$"]
  VoxProj["$$\\begin{array}{c}\\textbf{Voxel projection stats}\\\\\\Pi(\\mathbf{x})=\\texttt{transform\\_points\\_screen}(C_q,\\mathbf{x})\\\\\\mathbf{s}_{\\mathrm{vox}}=\\texttt{stats}(\\Pi(\\mathbf{p}))\\end{array}$$"]

  FiLM["$$\\begin{array}{c}\\textbf{FiLM modulation}\\\\(336\\ \\text{params})\\\\(\\gamma,\\beta)=\\texttt{nn.Linear}(\\mathbf{s}_{\\mathrm{vox}})\\\\\\tilde{\\mathbf{g}}=(1+\\gamma)\\odot\\mathbf{g}+\\beta\\\\\\texttt{nn.GroupNorm}\\end{array}$$"]
  GOut["$$\\begin{array}{c}\\textbf{Global feature}\\\\\\tilde{\\mathbf{g}}\\end{array}$$"]

  Field -->|"$$\\texttt{FloatTensor}[B,F_g,V,V,V]$$"| GlobalPool
  PoseEnc -->|"$$\\texttt{FloatTensor}[B,N_q,F_{\\mathrm{pose}}]$$"| GlobalPool
  GlobalPool -->|"$$\\texttt{FloatTensor}[B,N_q,F_g]$$"| GlobalPoolOps
  GlobalPoolOps -->|"$$\\texttt{FloatTensor}[B,N_q,F_g]$$"| FiLM

  Field -->|"$$\\texttt{FloatTensor}[B,F_g,V,V,V]$$"| VoxPool
  VoxPool -->|"$$\\texttt{FloatTensor}[B,F_g,G_{\\mathrm{pool}},G_{\\mathrm{pool}},G_{\\mathrm{pool}}]$$"| VoxProj
  Cam -->|"$$\\texttt{PerspectiveCameras}[B\\cdot N_q]$$"| VoxProj
  VoxProj -->|"$$\\texttt{FloatTensor}[B,N_q,F_{\\mathrm{vox}}]$$"| FiLM
  FiLM -->|"$$\\texttt{FloatTensor}[B,N_q,F_g]$$"| GOut

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class Field,PoseEnc,Cam input;
  class GlobalPool,GlobalPoolOps,VoxPool,VoxProj,FiLM compute;
  class GOut output;
