flowchart TB
  %% Semidense projection stats (compact)

  SemPts["$$\\begin{array}{c}\\textbf{Semidense points}\\\\\\mathbf{P}_{\\mathrm{sem}}\\end{array}$$"]
  Cam["$$\\begin{array}{c}\\textbf{Candidate cameras}\\\\C_q\\end{array}$$"]
  Proj["$$\\begin{array}{c}\\textbf{Screen-space projection}\\\\\\Pi(\\bullet)=\\texttt{transform\\_points\\_screen}(C_q,\\bullet)\\end{array}$$"]
  Stats["$$\\begin{array}{c}\\textbf{Projection statistics}\\\\\\mathbf{s}_{\\mathrm{proj}}=\\texttt{proj\\_stats}(\\bullet)\\\\\\left[\\mathrm{coverage},\\ \\mathrm{empty},\\ \\nu_{\\mathrm{sem}},\\ \\mu_z,\\ \\sigma_z\\right]\\end{array}$$"]
  Out["$$\\begin{array}{c}\\textbf{Semidense proj feat}\\\\\\mathbf{s}_{\\mathrm{proj}}\\end{array}$$"]

  SemPts -->|"$$\\texttt{FloatTensor}[B,P,C_{\\mathrm{sem}}]$$"| Proj
  Cam -->|"$$\\texttt{PerspectiveCameras}[B\\cdot N_q]$$"| Proj
  Proj -->|"$$\\begin{array}{c}\\texttt{FloatTensor}[B,N_q,P]\\\\\\texttt{BoolTensor}[B,N_q,P]\\end{array}$$"| Stats
  Stats -->|"$$\\texttt{FloatTensor}[B,N_q,F_{\\mathrm{proj}}]$$"| Out

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
