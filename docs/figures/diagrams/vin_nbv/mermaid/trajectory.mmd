flowchart TB
  %% Optional trajectory context (compact)

  Inputs["$$\\begin{array}{c}\texttt{Trajectory poses}\\\\\mathbf{T}^{w}_{rig}(t),\ \mathbf{T}^{w}_{r}\end{array}$$"]
  PoseEmb["$$\\begin{array}{c}\mathbf{e}\\\\\in\mathbb{R}^{B\times N_q\times F_{pose}}\end{array}$$"]

  Rel["$$\\begin{array}{c}\texttt{rig\_relative}\\\\\mathbf{T}^{r}_{rig}(t)=(\mathbf{T}^{w}_{r})^{-1}\mathbf{T}^{w}_{rig}(t)\end{array}$$"]
  Enc["$$\\begin{array}{c}\texttt{TrajectoryEncoder}\\\\\mathbf{t}\end{array}$$"]
  Attn["$$\\begin{array}{c}\texttt{MultiheadAttention}\\\\\mathbf{z}_{traj}\end{array}$$"]

  Out["$$\\begin{array}{c}\mathbf{z}_{traj}\\\\\in\mathbb{R}^{B\times N_q\times F_{pose}}\end{array}$$"]

  Inputs -->|"$$\mathbf{T}^{w}_{rig}(t),\mathbf{T}^{w}_{r}$$"| Rel
  Rel -->|"$$\mathbf{T}^{r}_{rig}(t)$$"| Enc
  Enc -->|"$$\mathbf{t}$$"| Attn
  PoseEmb -->|"$$\mathbf{e}$$"| Attn
  Attn -->|"$$\mathbf{z}_{traj}$$"| Out

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class Inputs,PoseEmb input;
  class Rel,Enc,Attn compute;
  class Out output;
