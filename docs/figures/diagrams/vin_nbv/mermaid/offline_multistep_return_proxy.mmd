---
config:
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 22
    rankSpacing: 24
  layout: elk
  themeVariables:
    fontSize: "20px"
  themeCSS: |
    .nodeLabel { font-size: 20px; }
    .edgeLabel { font-size: 18px; }
    .cluster-label { font-size: 22px; font-weight: 700; }
---
flowchart LR
  subgraph Gen["1. Generate Top-k Chains"]
    direction LR
    Snip["Logged snippet<br/>mesh + semi-dense"] --> Roll["Rollout tree<br/>root -> shell -> expand H"]
  end

  subgraph Ret["2. Oracle Reward + Return Proxy"]
    direction LR
    Roll --> Reward["Oracle step reward<br/>RRI(q_t)"]
    Reward --> Return["Return proxy<br/>G_t^H + cumulative RRI"]
  end

  subgraph Persist["3. Canonical Persistence"]
    direction LR
    Roll --> Chain["Top-k chains<br/>poses + idx + metrics"]
    Return --> Cf["counterfactuals record<br/>rewards + return"]
    Chain --> Cf
    Base["Existing base sample<br/>vin.* / oracle.* / backbone.*"] --> Store["vin_offline sample"]
    Cf --> Store
    Store --> Use["planner / RL dataset<br/>future return model"]
  end
  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;

  class Snip,Base input;
  class Roll,Reward,Return compute;
  class Chain,Cf,Store data;
  class Use output;

  style Gen fill:#f1fff6,stroke:#97ddb5,stroke-width:2px,rx:12,ry:12
  style Ret fill:#f7f3ff,stroke:#cdb2ff,stroke-width:2px,rx:12,ry:12
  style Persist fill:#f0fbff,stroke:#8fd0ff,stroke-width:2px,rx:12,ry:12
