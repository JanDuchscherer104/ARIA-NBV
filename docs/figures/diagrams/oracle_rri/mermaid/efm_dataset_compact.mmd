flowchart LR
  %% Dataset stage: ASE (ATEK WDS) -> EfmSnippetView (+ optional GT mesh)
  %%
  %% Symbols:
  %% - T: snippet length (frames)
  %% - P_t: semi-dense SLAM points (per snippet)
  %% - V,F: mesh vertices / faces

  shards["ASE shards (.tar)<br/>\(\texttt{WebDataset}\)"]
  meshes["GT meshes per scene<br/>\(\mathcal{M}_{GT}\)"]

  loader["EFM adaptor<br/>\(\texttt{load\_atek\_wds\_dataset}\)<br/>\(\texttt{EfmModelAdaptor}\)"]
  bounds["Infer bounds<br/>\(\texttt{infer\_semidense\_bounds}\)<br/>\(\texttt{AABB}\)"]
  meshproc["Mesh attach / process (opt.)<br/>\(\texttt{load\_or\_process\_mesh}\)<br/>\(\texttt{crop},\texttt{simplify}\)"]

  sample["Output: EfmSnippetView<br/>\(\texttt{efm}:\texttt{dict}\)<br/>\(\mathcal{M}_{GT}\) + \(\texttt{crop\_bounds}\)"]

  shards -->|"\(\texttt{raw atek sample}\)"| loader
  loader -->|"\(\texttt{efm}:\texttt{dict}\)"| bounds
  meshes -->|"\(\mathcal{M}_{GT}\)"| meshproc
  bounds -->|"\(\texttt{crop\_bounds}\in\mathbb{R}^{2\times 3}\)"| meshproc
  loader -->|"\(\texttt{efm}\)"| sample
  meshproc -->|"\(\mathbf{V}^w\in\mathbb{R}^{V\times 3},\ \mathcal{F}_{GT}\in\mathbb{N}^{F\times 3}\)"| sample

  %% Downstream-relevant interfaces (semantic summary)
  sample_out1["Provides to pipeline<br/>\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{T}\)<br/>\(\mathcal{P}_t\in\mathbb{R}^{P_t\times 3}\)<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w,\mathcal{F}_{GT})\)"]
  sample -->|"\(\texttt{typed accessors}\)"| sample_out1

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class shards,meshes input;
  class loader,bounds,meshproc compute;
  class sample neutral;
  class sample_out1 output;
