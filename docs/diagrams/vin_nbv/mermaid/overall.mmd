flowchart LR
  %% Overall VIN-NBV / VIN v2 forward (block-level)
  %%
  %% Symbols (dims):
  %% - B: batch size (snippets)
  %% - N: number of candidate views
  %% - T: trajectory length (frames)
  %% - P: semidense points (sampled), P <= P_proj
  %% - D,H,W: EVL voxel grid resolution
  %% - G_pool: pooling grid size, M = G_pool^3 pooled tokens
  %% - G_proj: projection stats grid size (G_proj^2 bins)
  %% - C_sem: semidense point feature dim (XYZ + extras)
  %% - F_in: scene field channel dim (selected inputs)
  %% - F_pose: pose vector dim (e.g. translation + R6D)
  %% - F_q: candidate pose embedding dim (queries)
  %% - F_g: global feature dim (voxel/global)
  %% - F_proj: semidense projection stats dim
  %% - F_tok: frustum token feature dim
  %% - F_fr: frustum summary dim (typically = F_g)
  %% - F_tau: trajectory feature dim
  %% - F_pt: point encoder dim (optional)
  %% - F_aux: auxiliary scalar dim (optional)
  %% - F_head: concatenated head input dim
  %% - K: number of ordinal bins (CORAL)

  subgraph Inputs
    batch["VinOracleBatch<br/>(meta, efm, candidates)"]
    cands["candidates<br/>\(\mathbf{T}_{q}^{w}\in\mathrm{SE}(3)^{B\times N}\)"]
    ref["reference pose<br/>\(\mathbf{T}_{r}^{w}\in\mathrm{SE}(3)^{B}\)"]
    cams["candidate cameras<br/>\(\texttt{PerspectiveCameras}\ (B\cdot N)\)"]
    efm["EFM snippet<br/>imgs+calib+poses<br/>semidense points"]
  end

  evl["Frozen EVL backbone<br/>\(\texttt{EvlBackbone}\)"]
  bout["backbone_out<br/>\(\texttt{EvlBackboneOutput}\)<br/>voxel heads + metadata"]

  prep["prepare_inputs<br/>\(\texttt{rotate\_yaw\_cw90}^{-1}\)<br/>broadcast \(B,N\)"]
  pose["Pose encoder<br/>\(\texttt{PoseEncoder}\)<br/>\(e_i=\texttt{pose\_enc}\)"]
  field["Scene field<br/>\(\texttt{field\_proj}\)<br/>\(\texttt{nn.Conv3d}+\texttt{nn.GroupNorm}+\texttt{nn.GELU}\)"]
  global["Global context<br/>\(\texttt{PoseConditionedGlobalPool}\)<br/>\(\texttt{nn.MultiheadAttention}\)"]
  semproj["Semidense stats<br/>\(\texttt{project} \rightarrow s^{proj}\)"]
  semfrus["Semidense frustum (opt.)<br/>\(\texttt{nn.MultiheadAttention}\)<br/>\(\rightarrow s^{fr}\)"]
  traj["Trajectory context<br/>\(\texttt{TrajectoryEncoder}\)<br/>\(\texttt{nn.MultiheadAttention}\)"]
  point["Point encoder (opt.)<br/>\(\texttt{PointNeXtSEncoder}\)<br/>\(\rightarrow z^{pt}\)"]

  concat["Feature fusion<br/>\(h_i=[e_i;g_i;s_i^{proj};s_i^{fr};z_i^{traj};z^{pt};u_i]\)"]
  head["Scoring head<br/>\(\texttt{nn.MLP}+\texttt{CoralLayer}\)"]
  out["Outputs<br/>\(\texttt{logits},\texttt{prob},\texttt{expected}\)<br/>\(\texttt{candidate\_valid}\) + priors"]

  %% Edges with shape labels (LaTeX-style text)
  batch -->|"\(\mathbf{T}_{q}^{w}\in\mathrm{SE}(3)^{B\times N}\)"| cands
  batch -->|"\(\mathbf{T}_{r}^{w}\in\mathrm{SE}(3)^{B}\)"| ref
  batch -->|"\(\texttt{efm}:\texttt{dict}\)"| efm

  efm -->|"\(\texttt{imgs, calib, poses}\)"| evl
  evl -->|"\(\texttt{backbone\_out}\)"| bout

  cands -->|"\(\mathbf{T}_{q}^{w}\)"| prep
  ref -->|"\(\mathbf{T}_{r}^{w}\)"| prep
  prep -->|"\(\texttt{pose\_vec}:(B,N,F_{pose})\)"| pose

  bout -->|"\(\texttt{field\_in}:(B,F_{in},D,H,W)\)"| field
  field -->|"\(\texttt{field}:(B,F_g,D,H,W)\)"| global
  pose -->|"\(e:(B,N,F_q)\)"| global

  efm -->|"\(\mathbf{X}_{world}:(B,P,C_{sem}),\ P\le P_{proj}\)"| semproj
  cams -->|"\(\texttt{PerspectiveCameras}:(B\cdot N)\)"| semproj
  pose -->|"\(q \leftarrow \texttt{pose\_enc}\)"| semfrus
  semproj -->|"\(\texttt{proj\_data}\Rightarrow \tau_{i,k}\)"| semfrus

  efm -->|"\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{B\times T}\)"| traj
  pose -->|"\(Q:e\)"| traj
  efm -->|"\(\mathbf{X}_{world}\)"| point

  pose -->|"\(e:(B,N,F_q)\)"| concat
  global -->|"\(g:(B,N,F_g)\)"| concat
  semproj -->|"\(s^{proj}:(B,N,F_{proj})\)"| concat
  semfrus -->|"\(s^{fr}:(B,N,F_{fr})\)"| concat
  traj -->|"\(z^{traj}:(B,N,F_\tau)\)"| concat
  point -->|"\(z^{pt}:(B,N,F_{pt})\)"| concat
  prep -->|"\(u_i:(B,N,F_{aux})\)"| concat

  concat -->|"\(h:(B,N,F_{head})\)"| head
  head -->|"\(\texttt{logits}:(B,N,K-1)\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef backbone fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class batch,cands,ref,cams,efm input;
  class evl,bout backbone;
  class prep,concat neutral;
  class pose,field,global,semproj,semfrus,traj,head compute;
  class out output;
