flowchart LR
  %% Submodule: Scene field builder + projection
  %%
  %% Symbols:
  %% - B: batch size
  %% - D,H,W: voxel grid resolution
  %% - F_in: selected input channel dim
  %% - F_g: projected field feature dim

  occ["Input<br/>\(\texttt{occ\_pr}\)"]
  cent["Input<br/>\(\texttt{cent\_pr}\)"]
  counts["Input<br/>\(\texttt{counts}\)"]
  occin["Input<br/>\(\texttt{occ\_input}\)"]

  derive["Derived channels<br/>\(\texttt{counts\_norm}=\frac{\log(1+c)}{\log(1+c_{\max})}\)<br/>\(\texttt{unknown}=1-\texttt{counts\_norm}\)<br/>\(\texttt{free\_input}=\texttt{observed}\cdot(1-\texttt{occ\_input})\)<br/>\(\texttt{new\_surface\_prior}=\texttt{unknown}\cdot\texttt{occ\_pr}\)"]
  concat["Select + concat<br/>\(\texttt{field\_in}=\texttt{concat}(\texttt{scene\_field\_channels})\)"]
  proj["Field projection<br/>\(\texttt{nn.Conv3d}(F_{in}\!\rightarrow\!F_g,\,1^3)\)<br/>\(+\ \texttt{nn.GroupNorm}+\texttt{nn.GELU}\)"]
  out["Output<br/>\(\texttt{field}\)"]

  occ -->|"\(\texttt{occ\_pr}:(B,1,D,H,W)\)"| derive
  cent -->|"\(\texttt{cent\_pr}:(B,1,D,H,W)\)"| derive
  counts -->|"\(\texttt{counts}:(B,D,H,W)\)"| derive
  occin -->|"\(\texttt{occ\_input}:(B,1,D,H,W)\)"| derive

  derive -->|"\(\texttt{field\_in}:(B,F_{in},D,H,W)\)"| concat
  concat -->|"\(\texttt{field\_in}\)"| proj
  proj -->|"\(\texttt{field}:(B,F_g,D,H,W)\)"| out

  classDef input fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class occ,cent,counts,occin input;
  class derive,concat neutral;
  class proj compute;
  class out output;
