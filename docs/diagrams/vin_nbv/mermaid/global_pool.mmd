flowchart LR
  %% Submodule: Pose-conditioned global pooling (+ voxel gate)
  %%
  %% Symbols:
  %% - B: batch size
  %% - N: number of candidate views
  %% - D,H,W: voxel grid resolution, V = D·H·W voxel centers
  %% - G_pool: pooling grid size, M = G_pool^3 pooled tokens
  %% - F_q: pose embedding dim
  %% - F_g: global feature dim

  field["Input<br/>\(\texttt{field}\)"]
  pose["Input<br/>\(\texttt{pose\_enc}\)"]
  pts["Input<br/>\(\texttt{voxel/pts\_world}\)"]
  Twv["Input<br/>\(\mathbf{T}_{voxel}^{w}\)"]
  ext["Input<br/>\(\texttt{voxel\_extent}\)"]

  posgrid["Pos grid in rig-ref frame<br/>\(\texttt{pos\_grid\_from\_pts\_world}\)"]
  pool["Pool voxels<br/>\(\texttt{pool\_size}=G_{pool}\Rightarrow M=G_{pool}^3\)<br/>\(\texttt{tokens}\in\mathbb{R}^{B\times M\times F_g}\)"]
  keypos["Positional keys (LFF)<br/>\(\texttt{LearnableFourierFeatures}(3\rightarrow F_g)\)"]
  attn["Pose-conditioned pooling<br/>\(\texttt{nn.MultiheadAttention}\)<br/>\(\tilde{g}_i=\mathrm{Attn}(e_i,\ tokens{+}pos)\)"]
  pre["Pre-gate global<br/>\(\tilde{g}\in\mathbb{R}^{B\times N\times F_g}\)"]

  vfrac["voxel_valid_frac<br/>\((B,N)\)<br/>(sample counts_norm @ cam center)"]
  gate["Voxel gate<br/>\(\texttt{nn.Linear}(1\rightarrow F_g)+\texttt{nn.Sigmoid}\)"]
  out["Output<br/>\(g=\gamma\odot\tilde{g}\in\mathbb{R}^{B\times N\times F_g}\)"]

  field -->|"\(\texttt{field}:(B,F_g,D,H,W)\)"| pool
  pool -->|"\(\texttt{tokens}:(B,M,F_g)\)"| attn
  pts -->|"\(\texttt{pts\_world}:(B,V,3)\)"| posgrid
  Twv -->|"\(\mathbf{T}_{voxel}^{w}\in\mathrm{SE}(3)^{B}\)"| posgrid
  ext -->|"\(\texttt{voxel\_extent}\in\mathbb{R}^{6}\)"| posgrid
  posgrid -->|"\(\texttt{pos\_grid}:(B,3,D,H,W)\)"| keypos
  keypos -->|"\(\texttt{pos\_key}:(B,M,F_g)\)"| attn
  pose -->|"\(e:(B,N,F_q)\)"| attn
  attn -->|"\(\tilde{g}:(B,N,F_g)\)"| pre
  pre -->|"\(\tilde{g}\)"| out

  vfrac -->|"unsqueeze \((B,N,1)\)"| gate
  gate -->|"\(\gamma:(B,N,F_g)\)"| out

  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef backbone fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class field,pose,vfrac input;
  class pts,Twv,ext backbone;
  class posgrid,pool,pre neutral;
  class keypos,attn,gate compute;
  class out output;
