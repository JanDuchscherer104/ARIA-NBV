flowchart LR
  %% Submodule: Semidense projection features (s^{proj})
  %%
  %% Symbols:
  %% - B: batch size, N: number of candidate views
  %% - P: sampled semidense points, P <= P_proj
  %% - C_sem: semidense point feature dim (XYZ + extras)
  %% - G_proj: grid size for coverage bins (G_proj^2 bins)
  %% - F_proj: projection feature dim

  pts["Input semidense points<br/>\(\mathbf{X}_{world}\)"]
  cam["Input candidate cameras<br/>\(\texttt{PerspectiveCameras}\)"]
  proj["Project to screen<br/>\(\texttt{transform\_points\_screen}\)"]
  bin["Grid binning<br/>\(G_{proj}^2\) bins"]
  stats["Coverage + depth stats<br/>\(s_i^{proj}=[\texttt{coverage},\texttt{empty\_frac},\texttt{vis\_frac},\mu_z,\sigma_z]\)"]
  out["Output<br/>\(\texttt{semidense\_proj}\)"]
  order["Feature order<br/>\([\texttt{coverage},\texttt{empty\_frac},\texttt{semidense\_candidate\_vis\_frac},\texttt{depth\_mean},\texttt{depth\_std}]\)"]

  pts -->|"\(\mathbf{X}_{world}:(B,P,C_{sem}),\ P\le P_{proj}\)"| proj
  cam -->|"\(\texttt{cameras}:(B\cdot N)\)"| proj
  proj -->|"\((x,y,z),\ \texttt{valid}\in\{0,1\}^{B N\times P}\)"| bin
  bin -->|"\(\texttt{counts}\in\mathbb{R}^{B N\times G_{proj}^2}\)"| stats
  proj -->|"\(z,\ \texttt{valid}\)"| stats
  stats -->|"\(s^{proj}:(B,N,F_{proj})\)"| out
  out -->|"\(\text{indexing}\)"| order

  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class pts,cam input;
  class proj,bin,stats,order neutral;
  class out output;
