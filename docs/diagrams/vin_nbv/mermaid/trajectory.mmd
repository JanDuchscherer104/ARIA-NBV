flowchart LR
  %% Submodule: Trajectory encoder + pose→traj attention (traj_ctx)
  %%
  %% Symbols:
  %% - B: batch size, N: number of candidate views
  %% - T: trajectory length
  %% - F_q: pose embedding dim (queries)
  %% - F_tau: trajectory feature dim

  traj["Input trajectory poses<br/>\(\mathbf{T}_{rig}^{w}(t)\)"]
  ref["Input reference pose<br/>\(\mathbf{T}_{r}^{w}\)"]
  tf["Transform to rig_ref<br/>\(\mathbf{T}_{rig}^{r}(t)=(\mathbf{T}_{r}^{w})^{-1}\mathbf{T}_{rig}^{w}(t)\)"]
  enc["TrajectoryEncoder<br/>\(\texttt{traj\_pose\_enc},\ \texttt{traj\_feat}\)"]
  pose["Input candidate pose_enc<br/>\(e_i\)"]
  attn["pose→traj attention<br/>\(\texttt{nn.MultiheadAttention}(embed\_dim=F_q,kdim=F_\tau)\)"]
  out["Output<br/>\(z_i^{traj}\)"]

  traj -->|"\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{B\times T}\)"| tf
  ref -->|"\(\mathbf{T}_{r}^{w}\in\mathrm{SE}(3)^{B}\)"| tf
  tf -->|"\(\mathbf{T}_{rig}^{r}(t)\)"| enc
  enc -->|"\(\texttt{traj\_pose\_enc}:(B,T,F_\tau)\)"| attn
  pose -->|"\(e:(B,N,F_q)\)"| attn
  attn -->|"\(z^{traj}:(B,N,F_q)\)"| out

  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class traj,ref,pose input;
  class tf neutral;
  class enc,attn compute;
  class out output;
