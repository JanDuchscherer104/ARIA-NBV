flowchart LR
  %% Stage: OracleRRI.score (oracle_rri.py)
  %% Expanded view (mesh cropping + CD distances + RRI)
  %%
  %% Symbols:
  %% - N: number of candidates
  %% - P_t: semi-dense SLAM points at time t
  %% - P_max: max candidate points (padded)
  %% - V,F: mesh vertices / faces

  pts_t["Input: current reconstruction<br/>\(\mathcal{P}_t\in\mathbb{R}^{P_t\times 3}\)"]
  pts_q["Input: candidate points<br/>\(\mathcal{P}_q\in\mathbb{R}^{N\times P_{max}\times 3}\)<br/>\(\texttt{lengths}_q\in\mathbb{N}^{N}\)"]
  mesh["Input: GT mesh<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w\in\mathbb{R}^{V\times 3},\ \mathcal{F}_{GT}\in\mathbb{N}^{F\times 3})\)"]
  aabb["Input: crop bounds<br/>\(\texttt{extend}\in\mathbb{R}^{6}\)"]

  crop["Crop mesh to AABB<br/>\((\mathbf{V}',\mathcal{F}')=\texttt{\_crop\_mesh\_to\_aabb}(\mathcal{M}_{GT},\texttt{extend})\)<br/>\(\tilde{\mathcal{M}}_{GT}=(\mathbf{V}',\mathcal{F}')\)"]

  dist_before["Distance before<br/>\(d_t=\mathrm{CD}(\mathcal{P}_t,\tilde{\mathcal{M}}_{GT})\)<br/>\(\texttt{chamfer\_point\_mesh}(\mathcal{P}_t,\mathbf{V}',\mathcal{F}')\)"]
  expand["Broadcast \(\mathcal{P}_t\) across candidates<br/>\(\mathcal{P}_t\rightarrow \mathcal{P}_{t}[1..N]\)"]
  union["Fuse points<br/>\(\mathcal{P}_{t\cup q}=\mathcal{P}_t\cup\mathcal{P}_q\)"]
  lengths["Union lengths<br/>\(\texttt{lengths}_{t\cup q}=\texttt{lengths}_q + P_t\)"]

  dist_after["Distance after (batched)<br/>\(d_{t\cup q}=\mathrm{CD}(\mathcal{P}_{t\cup q},\tilde{\mathcal{M}}_{GT})\)<br/>\(\texttt{chamfer\_point\_mesh\_batched}(\mathcal{P}_{t\cup q},\texttt{lengths}_{t\cup q},\mathbf{V}',\mathcal{F}')\)"]
  rri["Compute RRI<br/>\(\mathrm{RRI}(q)=\frac{d_t-d_{t\cup q}}{d_t+\epsilon}\)"]

  out["Output: RriResult<br/>\(\texttt{rri}\in\mathbb{R}^{N}\)<br/>\(\texttt{pm\_acc/comp/dist}\) before/after"]

  %% Dataflow
  mesh -->|"\(\mathcal{M}_{GT}\)"| crop
  aabb -->|"\(\texttt{extend}\)"| crop
  pts_t -->|"\(\mathcal{P}_t\)"| dist_before
  crop -->|"\((\mathbf{V}',\mathcal{F}')\)"| dist_before

  pts_t -->|"\(\mathcal{P}_t\)"| expand
  expand -->|"\(\mathcal{P}_t\) (batched)"| union
  pts_q -->|"\(\mathcal{P}_q\)"| union
  pts_q -->|"\(\texttt{lengths}_q\)"| lengths

  union -->|"\(\mathcal{P}_{t\cup q}\)"| dist_after
  lengths -->|"\(\texttt{lengths}_{t\cup q}\)"| dist_after
  crop -->|"\((\mathbf{V}',\mathcal{F}')\)"| dist_after

  dist_before -->|"\(d_t\)"| rri
  dist_after -->|"\(d_{t\cup q}\)"| rri
  rri -->|"\(\mathrm{RRI}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class pts_t,pts_q,mesh,aabb input;
  class crop,dist_before,dist_after,rri compute;
  class expand,union,lengths neutral;
  class out output;
