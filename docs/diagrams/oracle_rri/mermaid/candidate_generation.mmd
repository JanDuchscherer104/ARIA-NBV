flowchart LR
  %% Stage: CandidateViewGenerator (candidate_generation.py)
  %% Expanded view (positional_sampling.py + orientations.py + candidate_generation_rules.py)
  %%
  %% Symbols:
  %% - B: snippet batch size
  %% - T: snippet length (trajectory frames)
  %% - N_s: sampled candidates before pruning (oversampled)
  %% - N: valid candidates after pruning
  %%
  %% Frames:
  %% - w: world frame
  %% - r: reference rig frame (sampling origin)
  %% - q: candidate camera frame

  sample["Input: EfmSnippetView<br/>\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{B\times T}\)<br/>\(\mathcal{M}_{GT}\) + \(\texttt{AABB}\)"]

  refpose["Select reference pose<br/>\(\mathbf{T}_{r}^{w}\leftarrow \mathbf{T}_{rig}^{w}(t^\*)\)"]
  cw90["Rotate for UI alignment<br/>\(\texttt{rotate\_yaw\_cw90}\)"]
  grav["Optional gravity alignment<br/>\(\tilde{\mathbf{T}}_{r}^{w}=\texttt{\_gravity\_align\_pose}(\mathbf{T}_{r}^{w})\)"]

  subgraph Sampling["Sampling (positional_sampling.py + orientations.py)"]
    dirs["Sample directions on \(\mathbb{S}^2\)<br/>\(\mathbf{d}_i\sim \texttt{HypersphericalUniform / PowerSpherical}\)"]
    caps["Apply az/elev caps<br/>\(\mathbf{d}_i \leftarrow \texttt{\_scale\_into\_caps}(\mathbf{d}_i)\)"]
    rad["Sample radius<br/>\(\rho_i\sim \mathcal{U}(\rho_{min},\rho_{max})\)"]
    offs["Offsets in ref frame<br/>\(\mathbf{o}_i^{r}=\rho_i\mathbf{d}_i\in\mathbb{R}^{3}\)"]
    centers["Centers in world<br/>\(\mathbf{c}_i^{w}=\mathbf{T}_{r}^{w}\,\mathbf{o}_i^{r}\in\mathbb{R}^{3}\)"]

    base["Base orientation<br/>\(\mathbf{R}_{q}^{w}=\texttt{ViewDirectionMode}(\mathbf{T}_{r}^{w},\mathbf{c}_i^{w})\)"]
    jitter["Optional view jitter<br/>\(\Delta\mathbf{R}\leftarrow \texttt{yaw/pitch/roll}\)"]
    poses["Shell poses (cam2world)<br/>\(\mathbf{T}_{q}^{w}(i)=\texttt{PoseTW.from\_Rt}(\mathbf{R}_{q}^{w}\Delta\mathbf{R},\mathbf{c}_i^{w})\)"]
  end

  subgraph Pruning["Rule-based pruning (candidate_generation_rules.py)"]
    ctx["CandidateContext<br/>(mesh, verts/faces, bounds,<br/>centers, shell_poses, mask)"]
    free["FreeSpaceRule<br/>\(\mathbf{c}_i^{w}\in\texttt{AABB}\)"]
    dist["MinDistanceToMeshRule<br/>\(d_i=\min_{x\in\mathcal{M}_{GT}}\lVert \mathbf{c}_i^{w}-x\rVert_2\)"]
    coll["PathCollisionRule<br/>\(\texttt{segment}(\mathbf{T}_{r}^{w}.t\rightarrow \mathbf{c}_i^{w})\cap\mathcal{M}_{GT}=\emptyset\)"]
    mask["Update mask<br/>\(\texttt{mask\_valid}\in\{0,1\}^{N_s}\)"]
  end

  final["Finalise candidates<br/>\(\mathbf{T}_{q}^{r}=(\mathbf{T}_{r}^{w})^{-1}\mathbf{T}_{q}^{w}\)<br/>\(\mathbf{T}_{r}^{q}=(\mathbf{T}_{q}^{r})^{-1}\), \(\texttt{CameraTW.T\_camera\_rig}\leftarrow \mathbf{T}_{r}^{q}\)"]
  out["Output: CandidateSamplingResult<br/>\(\texttt{views}:\texttt{CameraTW}^{N}\)<br/>\(\mathbf{T}_{r}^{w}\) + \(\mathbf{T}_{q}^{w}\)<br/>\(\texttt{mask\_valid}\in\{0,1\}^{N_s}\)"]

  %% Dataflow
  sample -->|"\(\mathbf{T}_{rig}^{w}(t)\)"| refpose
  refpose -->|"\(\mathbf{T}_{r}^{w}\)"| cw90
  cw90 -->|"\(\mathbf{T}_{r}^{w}\)"| grav

  grav -->|"\(\tilde{\mathbf{T}}_{r}^{w}\)"| dirs
  dirs -->|"\(\mathbf{d}_i\)"| caps
  caps -->|"\(\mathbf{d}_i\)"| rad
  rad -->|"\(\rho_i\)"| offs
  offs -->|"\(\mathbf{o}_i^{r}\)"| centers
  grav -->|"\(\tilde{\mathbf{T}}_{r}^{w}\)"| centers

  centers -->|"\(\mathbf{c}_i^{w}\)"| base
  grav -->|"\(\tilde{\mathbf{T}}_{r}^{w}\)"| base
  base -->|"\(\mathbf{R}_{q}^{w}\)"| jitter
  jitter -->|"\(\Delta\mathbf{R}\)"| poses
  centers -->|"\(\mathbf{c}_i^{w}\)"| poses

  poses -->|"\(\mathbf{T}_{q}^{w}(i)\)"| ctx
  centers -->|"\(\mathbf{c}_i^{w}\)"| ctx
  sample -->|"\(\mathcal{M}_{GT},\ \texttt{AABB}\)"| ctx

  ctx -->|"\(\mathbf{c}_i^{w}\)"| free
  ctx -->|"\(\mathbf{c}_i^{w}\)"| dist
  ctx -->|"\(\mathbf{c}_i^{w}\)"| coll
  free -->|"\(\texttt{reject}\)"| mask
  dist -->|"\(\texttt{reject}\)"| mask
  coll -->|"\(\texttt{reject}\)"| mask

  poses -->|"\(\mathbf{T}_{q}^{w}\)"| final
  cw90 -->|"\(\mathbf{T}_{r}^{w}\)"| final
  mask -->|"\(\texttt{mask\_valid}\)"| final
  final -->|"\(\texttt{views}:\texttt{CameraTW}^{N}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class sample input;
  class refpose,cw90,grav neutral;
  class dirs,caps,rad,offs,centers,base,jitter,poses,ctx,free,dist,coll,mask,final compute;
  class out output;
