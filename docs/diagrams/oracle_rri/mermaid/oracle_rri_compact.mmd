flowchart LR
  %% Stage: OracleRRI.score (oracle_rri.py) -> RriResult
  %%
  %% Symbols:
  %% - N: number of candidates
  %% - P_t: semi-dense SLAM points at time t
  %% - P_max: max candidate points (padded)
  %% - V,F: mesh vertices / faces

  pts_t["Input current reconstruction<br/>\(\mathcal{P}_t\in\mathbb{R}^{P_t\times 3}\)"]
  pts_q["Input candidate points<br/>\(\mathcal{P}_q\in\mathbb{R}^{N\times P_{max}\times 3}\)"]
  mesh["Input GT mesh<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w\!\in\!\mathbb{R}^{V\times 3},\mathcal{F}_{GT}\!\in\!\mathbb{N}^{F\times 3})\)"]
  aabb["Crop bounds<br/>\(\texttt{extend}\in\mathbb{R}^{6}\)"]

  crop["Crop mesh to AABB<br/>\(\tilde{\mathcal{M}}_{GT}=\texttt{\_crop\_mesh\_to\_aabb}(\mathcal{M}_{GT},\texttt{extend})\)"]
  before["Distance before<br/>\(d_t=\mathrm{CD}(\mathcal{P}_t,\tilde{\mathcal{M}}_{GT})\)"]
  merge["Fuse points<br/>\(\mathcal{P}_{t\cup q}=\mathcal{P}_t\cup \mathcal{P}_q\)"]
  after["Distance after<br/>\(d_{t\cup q}=\mathrm{CD}(\mathcal{P}_{t\cup q},\tilde{\mathcal{M}}_{GT})\)"]
  rri["Relative improvement<br/>\(\mathrm{RRI}(q)=\frac{d_t-d_{t\cup q}}{d_t+\epsilon}\)"]

  out["Output: RriResult<br/>\(\texttt{rri}\in\mathbb{R}^{N}\)<br/>\(\texttt{pm\_dist\_before/after}\)"]

  mesh -->|"\(\mathcal{M}_{GT}\)"| crop
  aabb -->|"\(\texttt{extend}\)"| crop
  pts_t -->|"\(\mathcal{P}_t\)"| before
  crop -->|"\(\tilde{\mathcal{M}}_{GT}\)"| before
  pts_t -->|"\(\mathcal{P}_t\)"| merge
  pts_q -->|"\(\mathcal{P}_q\)"| merge
  merge -->|"\(\mathcal{P}_{t\cup q}\)"| after
  crop -->|"\(\tilde{\mathcal{M}}_{GT}\)"| after
  before -->|"\(d_t\)"| rri
  after -->|"\(d_{t\cup q}\)"| rri
  rri -->|"\(\mathrm{RRI}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class pts_t,pts_q,mesh,aabb input;
  class crop,before,merge,after,rri compute;
  class out output;
