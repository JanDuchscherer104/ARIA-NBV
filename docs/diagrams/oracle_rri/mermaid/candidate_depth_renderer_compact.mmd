flowchart LR
  %% Stage: CandidateDepthRenderer (candidate_depth_renderer.py) -> CandidateDepths
  %%
  %% Symbols:
  %% - N: number of rendered candidates
  %% - H,W: render resolution
  %% - V,F: mesh vertices / faces

  sample["Input: EfmSnippetView<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w,\mathcal{F}_{GT})\)"]
  cand["Input: CandidateSamplingResult<br/>\(\mathbf{T}_{q}^{w}\in\mathrm{SE}(3)^{N}\)<br/>\(\texttt{views}:\texttt{CameraTW}^{N}\)"]

  sel["Select candidates (cap/oversample)<br/>\(\texttt{\_select\_candidate\_views}\)"]
  scale["Optional intrinsics scaling<br/>\(\texttt{scale\_to\_size}\)"]
  render["Render depth<br/>\(D_q = \mathcal{R}(\mathcal{M}_{GT},C_q,q)\)<br/>\(\texttt{MeshRasterizer}\)"]
  mask["Valid mask<br/>\(\texttt{pix\_to\_face}\ge 0\)"]

  out["Output: CandidateDepths<br/>\(D_q\in\mathbb{R}^{N\times H\times W}\)<br/>\(\texttt{p3d\_cameras}\Rightarrow C_q\)"]

  sample -->|"\(\mathcal{M}_{GT}\)"| render
  cand -->|"\(\mathbf{T}_{q}^{w},\ C_q\)"| sel
  sel -->|"\(\mathbf{T}_{q}^{w}\)"| scale
  sel -->|"\(\texttt{CameraTW}\)"| scale
  scale -->|"\(C_q\)"| render
  scale -->|"\(\mathbf{T}_{q}^{w}\)"| render
  render -->|"\(D_q,\ \texttt{pix\_to\_face}\)"| mask
  mask -->|"\(D_q,\ \texttt{valid}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class sample,cand input;
  class sel,scale,mask neutral;
  class render compute;
  class out output;
