flowchart LR
  %% Stage: CandidateViewGenerator (candidate_generation.py) -> CandidateSamplingResult
  %%
  %% Symbols:
  %% - B: snippet batch size
  %% - T: snippet length (trajectory frames)
  %% - N: number of valid candidates returned
  %% - N_s: number of sampled candidates before pruning (oversampled)

  sample["Input: EfmSnippetView<br/>\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{B\times T}\)<br/>\(\mathcal{M}_{GT}\) + bounds"]

  refpose["Select reference pose<br/>\(\mathbf{T}_{r}^{w}\leftarrow \mathbf{T}_{rig}^{w}(t^\*)\)"]
  cw90["Display-frame rotation<br/>\(\texttt{rotate\_yaw\_cw90}\)"]
  gen["CandidateViewGenerator<br/>\(\texttt{generate}\)"]

  out["Output: CandidateSamplingResult<br/>\(\texttt{views}:\texttt{CameraTW}^{N}\)<br/>\(\texttt{mask\_valid}\in\{0,1\}^{N_s}\)"]

  sample -->|"\(\mathbf{T}_{rig}^{w}(t)\)"| refpose
  refpose -->|"\(\mathbf{T}_{r}^{w}\)"| cw90
  cw90 -->|"\(\mathbf{T}_{r}^{w}\) (sampling frame)"| gen
  sample -->|"\(\mathcal{M}_{GT},\ \texttt{AABB}\)"| gen

  gen -->|"\(q\in\mathcal{Q}\subset\mathrm{SE}(3)\ \Rightarrow\ \mathbf{T}_{q}^{w}\)"| out
  gen -->|"\(\texttt{views.T\_camera\_rig} \equiv \mathbf{T}_{r}^{q}\in\mathrm{SE}(3)^{N}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class sample input;
  class refpose,cw90 neutral;
  class gen compute;
  class out output;
