@startuml projectaria_core_classes
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam classBackgroundColor White
skinparam classArrowColor Black

package "projectaria_tools.core.sophus" {
    class SE3 {
        + {static} exp(trans, rot_vec): SE3
        + {static} from_matrix(T_4x4): SE3
        + {static} from_matrix3x4(T_3x4): SE3
        + {static} from_quat_and_translation(w, xyz, trans): SE3
        + to_matrix(): ndarray[4,4]
        + to_matrix3x4(): ndarray[3,4]
        + to_quat_and_translation(): ndarray[N,7]
        + inverse(): SE3
        + log(): ndarray[N,6]
        + rotation(): SO3
        + translation(): ndarray[N,3]
        + __matmul__(other): SE3 | ndarray
    }

    class SO3 {
        + {static} exp(rot_vec): SO3
        + {static} from_matrix(R_3x3): SO3
        + {static} from_quat(w, xyz): SO3
        + to_matrix(): ndarray[3,3]
        + to_quat(): ndarray[N,4]
        + inverse(): SO3
        + log(): ndarray[N,3]
        + __matmul__(other): SO3 | ndarray
    }

    SE3 *-- SO3 : contains
}

package "projectaria_tools.core.calibration" {
    class CameraCalibration {
        + project(point_3d): ndarray[2] | None
        + unproject(pixel): ndarray[3] | None
        + get_image_size(): Tuple[int, int]
        + get_focal_lengths(): Tuple[float, float]
        + get_principal_point(): Tuple[float, float]
        + get_transform_device_camera(): SE3
    }

    class DeviceCalibration {
        + get_camera_calib(label: str): CameraCalibration
        + get_imu_calib(label: str): ImuCalibration
        + get_all_labels(): List[str]
        + get_transform_device_sensor(label: str): SE3
        + get_origin_label(): str
    }

    DeviceCalibration "1" *-- "*" CameraCalibration : contains
    CameraCalibration ..> SE3 : uses
}

package "projectaria_tools.core.data_provider" {
    class VrsDataProvider {
        + get_image_data_by_index(stream_id, idx): Tuple
        + get_image_data_by_time_ns(stream_id, time, domain, option): Tuple
        + get_imu_data_by_index(stream_id, idx): ImuData
        + get_device_calibration(): DeviceCalibration
        + get_stream_id_from_label(label: str): StreamId
        + get_label_from_stream_id(stream_id): str
        + get_num_data(stream_id): int
        + get_first_time_ns(stream_id, domain): int
        + get_last_time_ns(stream_id, domain): int
        + deliver_queued_sensor_data(options): SensorDataIterator
    }

    class DeliverQueuedOptions {
        + activate_stream(stream_id): bool
        + deactivate_stream(stream_id): bool
        + set_subsample_rate(stream_id, rate): None
        + set_truncate_first_device_time_ns(time_ns): None
        + set_truncate_last_device_time_ns(time_ns): None
    }

    VrsDataProvider ..> DeviceCalibration : provides
    VrsDataProvider ..> DeliverQueuedOptions : uses
}

package "projectaria_tools.projects.ase" {
    class ASEReaders <<module>> {
        + {static} read_trajectory_file(path): dict
        + {static} read_points_file(path): ndarray
        + {static} read_language_file(path): List[Tuple]
    }

    class ASEInterpreter <<module>> {
        + {static} language_to_bboxes(entities): List[dict]
        + {static} get_ase_rgb_calibration(): CameraCalibration
    }

    ASEReaders ..> SE3 : returns
    ASEInterpreter ..> CameraCalibration : provides
}

note right of SE3
  **Key Transform Class**
  - Rotation + Translation (6 DOF)
  - Supports vectorized operations
  - Hamilton quaternion convention
  - Matrix multiplication with @ operator
end note

note right of CameraCalibration
  **Critical for NBV**
  - Handles fisheye distortion
  - Project 3D → 2D
  - Unproject 2D → 3D ray
  - Essential for depth→PC conversion
end note

@enduml
