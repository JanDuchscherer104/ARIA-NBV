@startuml projectaria_workflow
!theme plain

actor User
participant "VrsDataProvider" as VDP
participant "DeviceCalibration" as DC
participant "CameraCalibration" as CC
participant "SE3" as Transform
participant "ASE Readers" as ASE

== VRS Data Loading ==
User -> VDP: create_vrs_data_provider(vrs_path)
activate VDP
VDP --> User: provider
deactivate VDP

User -> VDP: get_stream_id_from_label("camera-rgb")
VDP --> User: stream_id

User -> VDP: get_image_data_by_index(stream_id, 0)
VDP --> User: (image_data, record)

== ASE Data Loading ==
User -> ASE: read_trajectory_file(traj_csv)
activate ASE
ASE --> User: {"Ts_world_from_device": List[SE3], ...}
deactivate ASE

User -> ASE: read_points_file(points_csv_gz)
ASE --> User: ndarray[N, 3]

User -> ASE: read_language_file(language_txt)
ASE --> User: List[(cmd, params)]

== Calibration & Transforms ==
User -> VDP: get_device_calibration()
VDP -> DC: create
activate DC
DC --> User: device_calib
deactivate DC

User -> DC: get_camera_calib("camera-rgb")
DC -> CC: create
activate CC
CC --> User: camera_calib
deactivate CC

User -> CC: get_transform_device_camera()
CC -> Transform: SE3 instance
activate Transform
Transform --> User: T_device_camera
deactivate Transform

== Projection Workflow ==
User -> Transform: T_camera_world = T_device_camera.inverse() @ T_world_device.inverse()
Transform --> User: T_camera_world

User -> Transform: point_camera = T_camera_world @ point_world
Transform --> User: point_camera

User -> CC: project(point_camera)
CC --> User: pixel [u, v] | None

== Unprojection Workflow ==
User -> CC: unproject([u, v])
CC --> User: ray [x, y, z] | None

User -> User: point_3d = depth * ray
User -> Transform: point_world = T_world_camera @ point_3d
Transform --> User: point_world

@enduml
