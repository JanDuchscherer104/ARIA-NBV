      "source": [
        "### Transforms"
      ],
      "id": "d49756a5"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "#| echo: true\n",
        "# SE3 creation\n",
        "T = SE3.from_quat_and_translation(w, xyz, translation)\n",
        "T = SE3.from_matrix(T_4x4)\n",
        "\n",
        "# SE3 operations\n",
        "T_inv = T.inverse()\n",
        "T_composed = T1 @ T2\n",
        "points_transformed = T @ points_3d"
      ],
      "id": "558abaa4",
      "execution_count": null,
      "outputs": []
    },
