        "#| eval: false\n",
        "#| echo: true\n",
        "# Projection\n",
        "pixel = camera_calib.project(point_in_camera)\n",
        "\n",
        "# Unprojection\n",
        "ray = camera_calib.unproject(pixel)\n",
        "point_3d = depth * ray\n",
        "\n",
        "# Extrinsics\n",
        "T_device_camera = camera_calib.get_transform_device_camera()"
