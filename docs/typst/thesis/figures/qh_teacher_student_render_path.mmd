---
config:
  theme: base
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 32
    curve: basis
  layout: elk
  themeVariables:
    background: "#ffffff"
    fontFamily: "Inter, DejaVu Sans, Arial, sans-serif"
    fontSize: "18px"
    primaryTextColor: "#1f2937"
    lineColor: "#64748b"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
    .cluster-label { font-size: 18px; font-weight: 700; }
---
flowchart TB
  subgraph Student["V1 student policy"]
    direction TB
    SState["$$\begin{array}{c}\textbf{Actor-visible state}\\\\ \boldsymbol{\mathcal{P}}_{t},\ \mathbf{F}_{0}^{\mathrm{EVL}},\mathbf{z}_{e},Q_t\end{array}$$"]
    SRender["$$\begin{array}{c}\textbf{Render current belief}\\\\ I_i^{\mathrm{belief}}=\operatorname{Render}(\boldsymbol{\mathcal{P}}_{t},\mathbf{F}_{0}^{\mathrm{EVL}},q_{t,i})\end{array}$$"]
    StudentQ["$$\begin{array}{c}\textbf{Student value}\\\\ Q_{H,\theta}(\boldsymbol{s}_{t}^{\mathrm{cf0}},\mathbf{z}_{e},q_{t,i})\end{array}$$"]
  end

  subgraph Teacher["Privileged teacher for training"]
    direction TB
    GTAssets["$$\begin{array}{c}\textbf{Oracle assets}\\\\ \boldsymbol{\mathcal{M}}_{\mathrm{GT}},\ M_e\end{array}$$"]
    GTRender["$$\begin{array}{c}\textbf{Dense GT render}\\\\ \mathbf{D}_{q},\ \boldsymbol{\mathcal{P}}_{q},\ \mathbf{M}_{q}\end{array}$$"]
    TeacherQ["$$\begin{array}{c}\textbf{Teacher value}\\\\ Q_{H}^{\mathrm{priv}}(s_t,z_e,q_{t,i},\mathbf{D}_{q})\end{array}$$"]
  end

  subgraph Losses["Training signals"]
    direction TB
    OracleLoss["$$\begin{array}{c}\textbf{Oracle return loss}\\\\ \mathcal{L}_{\mathrm{MC}}(Q_{H,\theta},G_t^{(H)})\end{array}$$"]
    DistillLoss["$$\begin{array}{c}\textbf{Distillation}\\\\ \mathcal{L}_{\mathrm{distill}}=\lVert Q_{H,\theta}-\operatorname{stopgrad}(Q_H^{\mathrm{priv}})\rVert_2^2\end{array}$$"]
    RankLoss["$$\begin{array}{c}\textbf{Masked ranking}\\\\ i:m_{t,i}=1\end{array}$$"]
  end

  Forbidden["$$\begin{array}{c}\textbf{Not used at V1 inference}\\\\ \mathbf{D}_{q}\ \texttt{as actor input}\end{array}$$"]

  SState --> SRender
  SRender --> StudentQ
  GTAssets --> GTRender
  GTRender --> TeacherQ
  StudentQ --> OracleLoss
  StudentQ --> DistillLoss
  StudentQ --> RankLoss
  TeacherQ -. "$$\texttt{values only}$$" .-> DistillLoss
  GTRender -. "$$\texttt{forbidden path}$$" .-> Forbidden

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class SState input;
  class SRender,StudentQ,TeacherQ,OracleLoss,DistillLoss,RankLoss compute;
  class GTAssets,GTRender data;
  class Forbidden output;

  style Student fill:#f1fff6,stroke:#97ddb5,stroke-width:2px,rx:12,ry:12
  style Teacher fill:#f7f3ff,stroke:#cdb2ff,stroke-width:2px,rx:12,ry:12
  style Losses fill:#f0fbff,stroke:#8fd0ff,stroke-width:2px,rx:12,ry:12
