---
config:
  theme: base
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 32
    curve: basis
  layout: elk
  themeVariables:
    background: "#ffffff"
    fontFamily: "Inter, DejaVu Sans, Arial, sans-serif"
    fontSize: "18px"
    primaryTextColor: "#1f2937"
    lineColor: "#64748b"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
    .cluster-label { font-size: 18px; font-weight: 700; }
---
flowchart LR
  subgraph EvidenceTop["Finite-candidate evidence contract"]
    direction LR
    Input["$$\begin{array}{c}\textbf{Actor-visible state}\\\\ \boldsymbol{s}_{t}^{\mathrm{obs}},\ \mathbf{z}_{e},\ Q_t\\\\ m_{t,i},\ \rho_{t,i}\end{array}$$"]
    Oracle["$$\begin{array}{c}\textbf{Target-RRI oracle}\\\\ M_{\mathrm{GT}},\ M_e,\ \boldsymbol{\mathcal{P}}_{q}\\\\ r_t^e,\ J_e^{(H)},\ \Delta_{\mathrm{look}}\end{array}$$"]
    Replay["$$\begin{array}{c}\textbf{One-step + rollouts}\\\\ \hat r_{t,i}^{e}=f_{\psi}^{\mathrm{VIN}}(\boldsymbol{s}_{t}^{\mathrm{cf0}},\mathbf{z}_{e},q_{t,i})\\\\ \texttt{random},\ \texttt{greedy},\ \texttt{lookahead},\ \texttt{softmax}\end{array}$$"]
  end

  subgraph EvidenceBottom["Learned planner and evaluation"]
    direction LR
    QH["$$\begin{array}{c}\textbf{Masked candidate-query }Q_H\\\\ Q_{H,\theta}(\boldsymbol{s}_{t}^{\mathrm{cf0}},\mathbf{z}_{e},q_{t,i})\\\\ \operatorname*{arg\,max}_{i:m_{t,i}=1}\ Q_{H,\theta}\end{array}$$"]
    Eval["$$\begin{array}{c}\textbf{Oracle re-evaluation}\\\\ J_e^{(H)},\ G_t^{(H)},\ \eta_Q\\\\ \mathrm{cost},\ \mathrm{invalidity},\ \mathrm{coverage}\end{array}$$"]
    Bridge["$$\begin{array}{c}\textbf{M6+ bridge}\\\\ \texttt{IQL},\ \texttt{online }Q_H\\\\ \texttt{actor-critic},\ \texttt{simulators}\end{array}$$"]
  end

  Input -->|"$$\texttt{valid rows}$$"| Oracle
  Oracle -->|"$$\texttt{labels + headroom}$$"| Replay
  Replay -->|"$$\texttt{masked replay}$$"| QH
  QH -->|"$$\pi_Q$$"| Eval
  Eval -. "$$\texttt{after M5 evidence}$$" .-> Bridge

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;
  classDef bridge fill:#fff7ed,stroke:#c2410c,stroke-width:1.3px,stroke-dasharray:5 4,rx:8,ry:8;

  class Input input;
  class Oracle,Replay data;
  class QH compute;
  class Eval output;
  class Bridge bridge;

  style EvidenceTop fill:#f7f3ff,stroke:#cdb2ff,stroke-width:2px,rx:12,ry:12
  style EvidenceBottom fill:#f0fbff,stroke:#8fd0ff,stroke-width:2px,rx:12,ry:12
