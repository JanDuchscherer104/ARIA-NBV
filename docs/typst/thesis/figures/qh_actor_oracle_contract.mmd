---
config:
  theme: base
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 32
    curve: basis
  layout: elk
  themeVariables:
    background: "#ffffff"
    fontFamily: "Inter, DejaVu Sans, Arial, sans-serif"
    fontSize: "18px"
    primaryTextColor: "#1f2937"
    lineColor: "#64748b"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
    .cluster-label { font-size: 18px; font-weight: 700; }
---
flowchart TB
  subgraph ActorVisible["V1 actor-visible inputs"]
    direction TB
    Points["$$\begin{array}{c}\textbf{Accumulated geometry}\\\\ \boldsymbol{\mathcal{P}}_{t}\end{array}$$"]
    EVL["$$\begin{array}{c}\textbf{Frozen EVL field}\\\\ \mathbf{F}_{0}^{\mathrm{EVL}}\end{array}$$"]
    Target["$$\begin{array}{c}\textbf{Target descriptor}\\\\ \mathbf{z}_{e}\\\\ \texttt{OBB + class + support}\end{array}$$"]
    Hist["$$\begin{array}{c}\textbf{History and budget}\\\\ \mathbf{h}_{t},\ b_t\end{array}$$"]
    Table["$$\begin{array}{c}\textbf{Candidate table}\\\\ Q_t,\ m_{t,i},\ \rho_{t,i}\end{array}$$"]
  end

  Interface["$$\begin{array}{c}\textbf{Legal }Q_H\textbf{ interface}\\\\ \boldsymbol{s}_{t}^{\mathrm{cf0}}=(\mathbf{F}_{0}^{\mathrm{EVL}},\boldsymbol{\mathcal{P}}_{t},\mathbf{z}_e,\mathbf{h}_t,b_t,Q_t,\mathbf{m}_t,\boldsymbol{\rho}_t)\\\\ Q_{H,\theta}(\boldsymbol{s}_{t}^{\mathrm{cf0}},\mathbf{z}_{e},q_{t,i})\end{array}$$"]
  Select["$$\begin{array}{c}\textbf{Masked action}\\\\ a_t=\operatorname*{arg\,max}_{i:m_{t,i}=1}Q_{H,\theta}(\cdot)\end{array}$$"]

  subgraph OracleOnly["Oracle-only assets"]
    direction TB
    Mesh["$$\begin{array}{c}\textbf{Scene and target GT}\\\\ \boldsymbol{\mathcal{M}}_{\mathrm{GT}},\ M_e\end{array}$$"]
    Boxes["$$\begin{array}{c}\textbf{GT boxes and labels}\\\\ \texttt{match}(\mathbf{z}_e,O_{\mathrm{GT}})\end{array}$$"]
    DenseRenders["$$\begin{array}{c}\textbf{Dense GT candidate renders}\\\\ \mathbf{D}_{q},\ \boldsymbol{\mathcal{P}}_{q}\end{array}$$"]
    Labels["$$\begin{array}{c}\textbf{Training and evaluation labels}\\\\ r_t^e,\ G_t^{(H)},\ J_e^{(H)}\end{array}$$"]
  end

  Teacher["$$\begin{array}{c}\textbf{Privileged teacher only}\\\\ Q_H^{\mathrm{priv}}\\\\ \texttt{distill values, not inputs}\end{array}$$"]
  Leak["$$\begin{array}{c}\textbf{Forbidden V1 input}\\\\ \texttt{GT crops / dense future renders}\\\\ \texttt{before action selection}\end{array}$$"]

  Points --> Interface
  EVL --> Interface
  Target --> Interface
  Hist --> Interface
  Table --> Interface
  Interface --> Select

  Mesh --> DenseRenders
  Mesh --> Labels
  Boxes --> Labels
  DenseRenders --> Labels
  Labels -. "$$\texttt{supervision only}$$" .-> Interface
  DenseRenders -. "$$\texttt{teacher branch}$$" .-> Teacher
  Teacher -. "$$\mathcal{L}_{\mathrm{distill}}$$" .-> Interface
  DenseRenders -. "$$\texttt{not actor-visible}$$" .-> Leak

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class Points,EVL,Target,Hist,Table input;
  class Interface,Select,Teacher compute;
  class Mesh,Boxes,DenseRenders,Labels data;
  class Leak output;

  style ActorVisible fill:#f1fff6,stroke:#97ddb5,stroke-width:2px,rx:12,ry:12
  style OracleOnly fill:#f7f3ff,stroke:#cdb2ff,stroke-width:2px,rx:12,ry:12
