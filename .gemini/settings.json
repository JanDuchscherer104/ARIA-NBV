{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run",
        "--profile",
        "default"
      ]
    },
    "code-index": {
      "command": "uvx",
      "args": [
        "code-index-mcp"
      ]
    },
    "mempalace": {
      "command": "bash",
      "args": [
        "-lc",
        "cd \"$(git rev-parse --show-toplevel)\" && exec aria_nbv/.venv/bin/python -m mempalace.mcp_server --palace .artifacts/mempalace/palace"
      ]
    }
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "check-agent-memory",
            "type": "command",
            "command": "make check-agent-memory >/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "exit",
        "hooks": [
          {
            "name": "debrief-nudge",
            "type": "command",
            "command": "scripts/debrief_nudge.sh || true"
          },
          {
            "name": "kg-auto-refresh",
            "type": "command",
            "command": "scripts/kg/auto_refresh.sh || true"
          }
        ]
      }
    ]
  }
}