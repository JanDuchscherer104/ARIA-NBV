---
config:
  theme: base
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 32
    curve: basis
  layout: elk
  themeVariables:
    background: "#ffffff"
    fontFamily: "Inter, DejaVu Sans, Arial, sans-serif"
    fontSize: "18px"
    primaryTextColor: "#1f2937"
    lineColor: "#64748b"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
    .cluster-label { font-size: 18px; font-weight: 700; }
---
flowchart TB
  %% ARIA-NBV scientific flowchart template.
  %% Replace placeholders, then run scripts/aria_mermaid_lint.py.

  Obs["$$\begin{array}{c}\textbf{Observation Stream}\\\boldsymbol{\mathcal{P}}^{\mathrm{semi}},\ \mathbf{T}^{w}_{\mathrm{rig}}(t)\end{array}$$"]
  Cand["$$\begin{array}{c}\textbf{Candidate Cameras}\\\mathbf{C}_{q},\ q\in\boldsymbol{\mathcal{Q}}\end{array}$$"]

  subgraph Model["ARIA-NBV model branch"]
    direction TB
    Enc["$$\begin{array}{c}\textbf{Encoder}\\\texttt{ModuleName}(\bullet)\end{array}$$"]
    Feat["$$\begin{array}{c}\textbf{Candidate Feature}\\\mathbf{F}_{q}^{\mathrm{vox}}\end{array}$$"]
    Head["$$\begin{array}{c}\textbf{RRI Head}\\\hat{r}_{q}\end{array}$$"]
  end

  Out["$$\begin{array}{c}\textbf{Selected NBV Action}\\q^{\star}=\operatorname*{arg\,max}_{q\in\boldsymbol{\mathcal{Q}}}\ \hat{r}_{q}\end{array}$$"]

  Obs -->|"$$\texttt{FloatTensor}[B,P,C_{\mathrm{sem}}]$$"| Enc
  Cand -->|"$$\texttt{PerspectiveCameras}[B\cdot N_q]$$"| Enc
  Enc -->|"$$\texttt{FloatTensor}[B,N_q,F_{\mathrm{field}}]$$"| Feat
  Feat -->|"$$\texttt{FloatTensor}[B,N_q,1]$$"| Head
  Head --> Out

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class Obs,Cand input;
  class Enc,Feat,Head compute;
  class Out output;

  style Model fill:#f0fbff,stroke:#8fd0ff,stroke-width:2px,rx:12,ry:12
