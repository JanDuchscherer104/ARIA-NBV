{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "make check-agent-memory >/dev/null || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "make agents-db AGENTS_ARGS='validate' >/dev/null || true"
          }
        ]
      }
    ]
  }
}
