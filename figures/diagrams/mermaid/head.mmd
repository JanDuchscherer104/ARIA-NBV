---
config:
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 34
  layout: elk
  themeVariables:
    fontSize: "18px"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
---
flowchart LR
  %% VINv3 head: feature fusion + CORAL decoding (edges = shapes only).

  subgraph Inputs["<b>Inputs</b>"]
    direction TB
    PoseEnc["pose_enc"]
    GlobalFeat["global_feat"]
    SemProj["semidense_proj"]
    SemGrid["semidense_grid_feat<br/>(optional)"]
    TrajCtx["traj_ctx<br/>(optional)"]
    ValidFrac["validity proxies"]
  end

  Concat["<b>Feature concat</b><br/><br/><code>feats = cat([pose_enc, global_feat, semidense_proj, ...], dim=-1)</code>"]

  Flatten["<b>Flatten</b><br/><br/><code>flat = reshape(feats, [B*N_q, -1])</code>"]
  HeadMLP["<b>MLP scorer</b> (58.2K params)<br/><br/><code>z = head_mlp(flat)</code><br/><code>nn.Linear -> nn.GELU -> nn.Dropout</code><br/><code>-> nn.Linear -> nn.GELU -> nn.Dropout</code>"]

  Coral["<b>CORAL logits</b> (221 params)<br/><br/><code>logits = reshape(CoralLayer(z), [B, N_q, K-1])</code>"]
  Decode["<b>Ordinal decoding</b><br/><br/><code>prob = coral_logits_to_prob(logits)  # K bins</code><br/><code>expected = sum(sigmoid(logits), dim=-1)</code><br/><code>expected_norm = expected / (K-1)  # r_hat</code>"]

  Mask["<b>candidate_valid mask</b><br/><br/><code>candidate_valid = finite &amp; (v_vox &gt; 0) &amp; (v_sem &gt; 0)</code>"]

  OutProb["prob"]
  OutExpected["expected"]
  OutExpectedNorm["expected_norm"]
  CandValid["candidate_valid"]
  Pred["VinPrediction<br/><code>{feats, logits, prob, expected, expected_norm, candidate_valid}</code>"]

  PoseEnc -->|"FloatTensor[B, N_q, F_pose]"| Concat
  GlobalFeat -->|"FloatTensor[B, N_q, F_g]"| Concat
  SemProj -->|"FloatTensor[B, N_q, F_proj]"| Concat
  SemGrid -->|"FloatTensor[B, N_q, F_fr]"| Concat
  TrajCtx -->|"FloatTensor[B, N_q, F_pose]"| Concat

  Concat -->|"FloatTensor[B, N_q,<br/>F_head]"| Flatten
  Flatten -->|"FloatTensor[B*N_q,<br/>F_head]"| HeadMLP
  HeadMLP -->|"FloatTensor[B*N_q,<br/>F_hid]"| Coral
  Coral -->|"FloatTensor[B, N_q,<br/>K-1]"| Decode

  Decode -->|"FloatTensor[B, N_q,<br/>K]"| OutProb
  Decode -->|"FloatTensor[B, N_q]"| OutExpected
  Decode -->|"FloatTensor[B, N_q]"| OutExpectedNorm

  %% VinPrediction fields (edges = shapes only).
  Concat -->|"FloatTensor[B, N_q,<br/>F_head]"| Pred
  Coral -->|"FloatTensor[B, N_q,<br/>K-1]"| Pred
  OutProb -->|"FloatTensor[B, N_q,<br/>K]"| Pred
  OutExpected -->|"FloatTensor[B, N_q]"| Pred
  OutExpectedNorm -->|"FloatTensor[B, N_q]"| Pred
  CandValid -->|"BoolTensor[B, N_q]"| Pred

  ValidFrac -->|"FloatTensor[B, N_q]"| Mask
  Mask -->|"BoolTensor[B, N_q]"| CandValid

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class PoseEnc,GlobalFeat,SemProj,SemGrid,TrajCtx,ValidFrac input;
  class Concat,Flatten,HeadMLP,Coral,Decode,Mask compute;
  class OutProb,OutExpected,OutExpectedNorm data;
  class Pred,CandValid output;
