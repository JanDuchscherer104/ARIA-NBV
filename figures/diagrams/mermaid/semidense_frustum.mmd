---
config:
  htmlLabels: true
  flowchart:
    htmlLabels: true
    nodeSpacing: 20
    rankSpacing: 32
  layout: elk
  themeVariables:
    fontSize: "18px"
  themeCSS: |
    .nodeLabel { font-size: 18px; }
    .edgeLabel { font-size: 16px; }
---
flowchart TB
  %% Semidense grid CNN (compact)

  ProjData["Projection data"]
  Grid["<b>Screen-space grid</b><br/><br/><code>grid = scatter_add(proj_data)</code><br/><code>channels: [occupancy, mu_z, sigma_z]</code>"]
  CNNTrunk["<b>Tiny CNN (part 1)</b> (1.3K params)<br/><br/><code>nn.Conv2d -> nn.GELU -> nn.Conv2d -> nn.GELU</code>"]
  CNNHead["<b>Tiny CNN (part 2)</b><br/><br/><code>nn.AdaptiveAvgPool2d -> nn.Flatten -> nn.Linear</code>"]
  Out["semidense_grid_feat"]

  ProjData -->|"FloatTensor[B, N_q, P]<br/>BoolTensor[B, N_q, P]"| Grid
  Grid -->|"FloatTensor[B*N_q,<br/>C_grid, G, G]"| CNNTrunk
  CNNTrunk -->|"FloatTensor[B*N_q,<br/>C_mid, G, G]"| CNNHead
  CNNHead -->|"FloatTensor[B, N_q, F_fr]"| Out

  classDef input fill:#D5E8D4,stroke:#82B366,stroke-width:1.5px,rx:0,ry:0;
  classDef output fill:#F8CECC,stroke:#B85450,stroke-width:1.5px,rx:0,ry:0;
  classDef compute fill:#E1D5E7,stroke:#9673A6,stroke-width:1.5px,rx:8,ry:8;
  classDef data fill:#F5F5F5,stroke:#9E9E9E,stroke-width:1.2px,rx:0,ry:0;

  class ProjData input;
  class Grid,CNNTrunk,CNNHead compute;
  class Out output;
