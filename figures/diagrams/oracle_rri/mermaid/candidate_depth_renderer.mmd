flowchart LR
  %% Stage: CandidateDepthRenderer (candidate_depth_renderer.py)
  %% Expanded view (includes pytorch3d_depth_renderer.py internals)
  %%
  %% Symbols:
  %% - N: rendered candidates
  %% - H,W: render resolution
  %% - V,F: mesh vertices / faces
  %%
  %% Frames:
  %% - w: world frame
  %% - r: reference rig frame
  %% - q: candidate camera frame

  sample["Input: EfmSnippetView<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w,\mathcal{F}_{GT})\)"]
  cand["Input: CandidateSamplingResult<br/>\(\texttt{views}:\texttt{CameraTW}^{N}\)<br/>\(\mathbf{T}_{r}^{w}\in\mathrm{SE}(3)\)"]

  sel["Select candidate subset<br/>\(\texttt{\_select\_candidate\_views}\)<br/>\(\texttt{candidate\_indices}\)"]
  posew["Derive cam2world poses<br/>\(\mathbf{T}_{q}^{w}=\mathbf{T}_{r}^{w}(\mathbf{T}_{r}^{q})^{-1}\)"]
  scale["Optional resolution scaling<br/>\(C_q\leftarrow \texttt{CameraTW.scale\_to\_size}\)"]

  p3d["Build PyTorch3D cameras<br/>\(\texttt{PerspectiveCameras}(R,T,C_q)\)"]
  rast["Rasterize mesh<br/>\(\texttt{MeshRasterizer}(\mathcal{M}_{GT})\Rightarrow (\texttt{zbuf},\texttt{pix\_to\_face})\)"]
  valid["Valid pixels<br/>\(\texttt{valid}=(\texttt{pix\_to\_face}\ge 0)\wedge(z\in[z_{near},z_{far}])\)"]

  out["Output: CandidateDepths<br/>\(D_q\in\mathbb{R}^{N\times H\times W}\)<br/>\(\texttt{p3d\_cameras}\Rightarrow C_q\) + \(\texttt{valid}\)"]

  %% Dataflow
  cand -->|"\(\texttt{views}:\texttt{CameraTW}^{N}\)"| sel
  cand -->|"\(\mathbf{T}_{r}^{w}\)"| posew
  sel -->|"\(\mathbf{T}_{r}^{q}=\texttt{views.T\_camera\_rig}\Rightarrow (\mathbf{T}_{r}^{q})^{-1}=\mathbf{T}_{q}^{r}\)"| posew
  posew -->|"\(\mathbf{T}_{q}^{w}\)"| scale
  sel -->|"\(C_q\)"| scale

  sample -->|"\(\mathcal{M}_{GT}\)"| rast
  scale -->|"\(C_q\)"| p3d
  posew -->|"\(\mathbf{T}_{q}^{w}\)"| p3d
  p3d -->|"\(\texttt{PerspectiveCameras}\)"| rast
  rast -->|"\(\texttt{zbuf}\equiv D_q,\ \texttt{pix\_to\_face}\)"| valid
  valid -->|"\(D_q,\ \texttt{valid}\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class sample,cand input;
  class sel,posew,scale neutral;
  class p3d,rast,valid compute;
  class out output;
