flowchart LR
  %% Stage: AseEfmDataset (efm_dataset.py) -> EfmSnippetView
  %% Expanded view (loader + bounds + mesh processing)
  %%
  %% Symbols:
  %% - T: snippet length (frames)
  %% - P_t: semi-dense SLAM points (collapsed / per snippet)
  %% - V,F: mesh vertices / faces

  shards["Input shards<br/>\(\texttt{*.tar}\) WebDataset"]
  mapping["Key mapping<br/>\(\texttt{EfmModelAdaptor.get\_dict\_key\_mapping\_all}\)"]
  efm_adapt["ATEK \(\rightarrow\) EFM<br/>\(\texttt{EfmModelAdaptor.atek\_to\_efm}\)"]
  efm_dict["EFM sample dict<br/>\(\texttt{efm}:\texttt{dict}\)"]

  bounds["Infer semidense bounds<br/>\(\texttt{infer\_semidense\_bounds}\)<br/>\(\texttt{crop\_bounds}=(\min,\max)\in\mathbb{R}^{2\times 3}\)"]

  mesh_load["Load scene mesh (opt.)<br/>\(\texttt{trimesh.load}\)"]
  mesh_proc["Process mesh (opt.)<br/>\(\texttt{load\_or\_process\_mesh}\)<br/>\(\texttt{crop},\texttt{simplify}\)"]
  mesh_tensors["Mesh tensors<br/>\(\mathbf{V}^w\in\mathbb{R}^{V\times 3}\)<br/>\(\mathcal{F}_{GT}\in\mathbb{N}^{F\times 3}\)"]

  sample["Output: EfmSnippetView<br/>\(\texttt{efm}:\texttt{dict}\)<br/>\(\mathcal{M}_{GT}\) + \(\texttt{mesh\_verts/faces}\)<br/>\(\texttt{crop\_bounds}\)"]

  iface["Downstream interfaces (examples)<br/>\(\mathbf{T}_{rig}^{w}(t)\in\mathrm{SE}(3)^{T}\)<br/>\(\mathcal{P}_t\in\mathbb{R}^{P_t\times 3}\)<br/>\(\mathcal{M}_{GT}=(\mathbf{V}^w,\mathcal{F}_{GT})\)"]

  shards -->|"\(\texttt{urls}\)"| mapping
  mapping -->|"\(\texttt{dict\_key\_mapping}\)"| efm_adapt
  efm_adapt -->|"\(\texttt{efm}:\texttt{dict}\)"| efm_dict

  efm_dict -->|"\(\texttt{points metadata / points}\)"| bounds
  efm_dict -->|"\(\texttt{sequence\_name},\ \texttt{\_\_key\_\_}\)"| sample

  efm_dict -->|"\(\texttt{scene\_id}\)"| mesh_load
  mesh_load -->|"\(\mathcal{M}_{GT}\)"| mesh_proc
  bounds -->|"\(\texttt{crop\_bounds}\)"| mesh_proc
  mesh_proc -->|"\(\mathbf{V}^w,\mathcal{F}_{GT}\)"| mesh_tensors

  efm_dict -->|"\(\texttt{efm}\)"| sample
  bounds -->|"\(\texttt{crop\_bounds}\)"| sample
  mesh_tensors -->|"\(\mathbf{V}^w,\mathcal{F}_{GT}\)"| sample

  sample -->|"\(\texttt{typed accessors}\)"| iface

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class shards input;
  class mapping,efm_adapt,bounds,mesh_load,mesh_proc,mesh_tensors compute;
  class efm_dict,sample neutral;
  class iface output;
