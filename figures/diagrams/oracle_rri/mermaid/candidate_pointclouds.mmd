flowchart LR
  %% Stage: build_candidate_pointclouds (candidate_pointclouds.py)
  %% Expanded view (depth -> point cloud + semidense fusion + bounds)
  %%
  %% Symbols:
  %% - N: rendered candidates
  %% - H,W: render resolution
  %% - s: backprojection stride (pixels)
  %% - P: sampled pixel grid points, \(P=\lvert\{0,s,2s,\dots\}\rvert^2\)
  %% - P_max: max valid points per candidate after masking
  %% - P_t: semi-dense SLAM points (collapsed)

  sample["Input: EfmSnippetView<br/>\(\mathcal{P}_t\in\mathbb{R}^{P_t\times 3}\)<br/>\(\texttt{occupancy\_extend}\in\mathbb{R}^{6}\)"]
  depths["Input: CandidateDepths<br/>\(D_q\in\mathbb{R}^{N\times H\times W}\)<br/>\(\texttt{valid}\in\{0,1\}^{N\times H\times W}\)<br/>\(\texttt{p3d\_cameras}\Rightarrow C_q\)"]

  grid["Pixel grid + stride<br/>\((u,v)\in\{0,s,2s,\dots\}^2\)"]
  ndc["Pixel \(\rightarrow\) NDC<br/>\((x_{ndc},y_{ndc})\)"]
  pack["Pack \((x_{ndc},y_{ndc},z)\)<br/>\(\texttt{xy\_depth}\in\mathbb{R}^{N\times P\times 3}\)"]
  unproj["Unproject to world<br/>\(\mathbf{X}_q^{w}=\Pi^{-1}(\texttt{xy\_depth})\)<br/>\(\texttt{PerspectiveCameras.unproject\_points}\)"]
  mask["Mask + compact<br/>\(\texttt{mask}=\texttt{finite}\wedge\texttt{valid}\)"]
  pad["Pad to \(\mathcal{P}_q\)<br/>\(\mathcal{P}_q\in\mathbb{R}^{N\times P_{max}\times 3}\)<br/>\(\texttt{lengths}\in\mathbb{N}^{N}\)"]

  semi["Collapse semidense cloud<br/>\(\mathcal{P}_t\leftarrow \texttt{semidense.collapse\_points}()\)"]
  bounds["Union bounds<br/>\(\texttt{extend}=\texttt{\_compute\_bounds}(\texttt{occupancy\_extend},\mathcal{P}_q,\mathcal{P}_t)\)"]

  out["Output: CandidatePointClouds<br/>\(\mathcal{P}_q,\ \texttt{lengths}\)<br/>\(\mathcal{P}_t\)<br/>\(\texttt{extend}\in\mathbb{R}^{6}\)"]

  %% Dataflow
  depths -->|"\(D_q,\ \texttt{valid}\)"| grid
  grid -->|"\((u,v)\)"| ndc
  ndc -->|"\((x_{ndc},y_{ndc})\)"| pack
  depths -->|"\(z=D_q[u,v]\)"| pack
  pack -->|"\(\texttt{xy\_depth}\)"| unproj
  depths -->|"\(\texttt{p3d\_cameras}\)"| unproj
  unproj -->|"\(\mathbf{X}_q^{w}\)"| mask
  depths -->|"\(\texttt{valid}\)"| mask
  mask -->|"\(\mathbf{X}_q^{w}\ \text{(filtered)}\)"| pad

  sample -->|"\(\mathcal{P}_t\)"| semi
  pad -->|"\(\mathcal{P}_q,\ \texttt{lengths}\)"| bounds
  semi -->|"\(\mathcal{P}_t\)"| bounds
  bounds -->|"\(\texttt{extend}\)"| out
  pad -->|"\(\mathcal{P}_q\)"| out
  semi -->|"\(\mathcal{P}_t\)"| out

  %% Styling
  classDef input fill:#d5e8d4,stroke:#82b366,stroke-width:2px;
  classDef compute fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;
  classDef neutral fill:#f5f5f5,stroke:#666666,stroke-width:2px;
  classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px;

  class sample,depths input;
  class grid,ndc,pack,mask,pad neutral;
  class unproj,semi,bounds compute;
  class out output;
