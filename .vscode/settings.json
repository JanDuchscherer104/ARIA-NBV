{
    "editor.formatOnSave": true,
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python-envs.defaultPackageManager": "ms-python.python:uv",
    "python-envs.pythonProjects": [],
    "python.defaultInterpreterPath": "${workspaceFolder}/aria_nbv/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.env.linux": {
        "CONDA_PREFIX": "/home/jd/.local/share/mamba/envs/aria-nbv",
        "CUDA_HOME": "/home/jd/.local/share/mamba/envs/aria-nbv",
        "FORCE_CUDA": "1",
        "TORCH_CUDA_ARCH_LIST": "8.6",
        "PATH": "/home/jd/.local/share/mamba/envs/aria-nbv/bin:${env:PATH}"
    },
    "python.analysis.extraPaths": [
        "${workspaceFolder}/external/PointNeXt"
    ],
    "ruff.configuration": "${workspaceFolder}/aria_nbv/pyproject.toml",
    "ruff.format.preview": true,
    "notebook.formatOnSave.enabled": true,
    "notebook.codeActionsOnSave": {
        "notebook.source.fixAll": "explicit",
        "notebook.source.organizeImports": "explicit"
    },
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "[markdown]": {
        "editor.formatOnSave": true
    },
    "tinymist.rootPath": "${workspaceFolder}/docs",
    "chatgpt.openOnStartup": false
}
