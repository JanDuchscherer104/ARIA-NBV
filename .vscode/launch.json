{
    "configurations": [
        {
            "name": "aria-nbv-cli",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aria_nbv/aria_nbv/lightning/cli.py",
            "console": "integratedTerminal",
            "args": [
                "--run-mode",
                "summarize-vin",
                "--config-path",
                "${workspaceFolder}/.configs/offline_only.toml"
            ]
        },
        {
            "name": "Python: Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/aria_nbv/aria_nbv/streamlit_app.py",
                "--server.port",
                "8501"
            ],
            "console": "integratedTerminal"
        }
    ]
}