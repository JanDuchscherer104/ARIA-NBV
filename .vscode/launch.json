{
    "configurations": [
        {
            "name": "aria-nbv-cli",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aria_nbv/aria_nbv/lightning/cli.py",
            "console": "integratedTerminal",
            "args": [
                "--run-mode",
                "summarize-vin",
                "--config-path",
                "${workspaceFolder}/.configs/offline_only.toml"
            ],
            "env": {
                "CONDA_PREFIX": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "CUDA_HOME": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "FORCE_CUDA": "1",
                "TORCH_CUDA_ARCH_LIST": "8.6",
                "PATH": "/home/jd/.local/share/mamba/envs/aria-nbv/bin:${env:PATH}"
            }
        },
        {
            "name": "ARIA: Build Rollouts V1 Smoke",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aria_nbv/.venv/bin/nbv-build-rollouts",
            "python": "${workspaceFolder}/aria_nbv/.venv/bin/python",
            "cwd": "${workspaceFolder}/aria_nbv",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--config-path",
                "${workspaceFolder}/.configs/build_rollouts_v1_smoke.toml"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1",
                "CONDA_PREFIX": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "CUDA_HOME": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "FORCE_CUDA": "1",
                "TORCH_CUDA_ARCH_LIST": "8.6",
                "PATH": "/home/jd/.local/share/mamba/envs/aria-nbv/bin:${env:PATH}"
            }
        },
        {
            "name": "Python: Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/aria_nbv/aria_nbv/streamlit_app.py",
                "--server.port",
                "8501"
            ],
            "console": "integratedTerminal",
            "env": {
                "CONDA_PREFIX": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "CUDA_HOME": "/home/jd/.local/share/mamba/envs/aria-nbv",
                "FORCE_CUDA": "1",
                "TORCH_CUDA_ARCH_LIST": "8.6",
                "PATH": "/home/jd/.local/share/mamba/envs/aria-nbv/bin:${env:PATH}"
            }
        }
    ]
}
